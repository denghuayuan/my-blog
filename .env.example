# Docker compose variable interpolation
WEB_PORT=80
DOMAIN=youer.me
DOMAIN_WWW=www.youer.me

# Server runtime
PORT=3000
MONGODB_URI=mongodb://mongo:27017/my-blog
CLIENT_URL=https://youer.me
SERVER_BASE_URL=https://youer.me
UPLOAD_DIR=uploads

# TLS (optional, when using Let's Encrypt on host)
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_DIR=/etc/letsencrypt
CERTBOT_WWW_DIR=/var/www/certbot
WEB_TLS_PORT=443

# Authentication
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=604800

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Web build-time variable
VITE_API_BASE_URL=/api